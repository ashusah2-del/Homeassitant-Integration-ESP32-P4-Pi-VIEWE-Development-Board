wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
fallback_ap_ssid: "guition-p4-ha-ap"
fallback_ap_password: "YOUR_AP_PASSWORD"
# Static IP the panel uses for OTA and ESPHome API (must match your DHCP reservation)
panel_use_address: "192.168.X.X"
# Full URL of your Immich server, e.g. http://192.168.1.50:2283
immich_server_url: "http://YOUR_IMMICH_HOST:2283"
# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"
# Generate with: openssl rand -base64 24
ota_password: "REPLACE_WITH_OTA_PASSWORD"
# Create in Immich → Account Settings → API Keys
immich_api_key: "REPLACE_WITH_IMMICH_API_KEY"
